@page "/records"
@inherits HevyPageBase<ExerciseSelectionFilters>

<PageTitle>Records</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Records</MudText>

@if (IsLoading)
{
    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
}
else if (!HasData)
{
    <MudAlert Severity="Severity.Info">@ErrorMessage</MudAlert>
}
else
{
    <MudPaper Class="filter-panel" Variant="Variant.Outlined">
        <MudGrid>
            <MudItem xs="12" sm="6" md="3"><MudDatePicker Label="From" Date="@Filters.From" DateChanged="OnFromChanged" /></MudItem>
            <MudItem xs="12" sm="6" md="3"><MudDatePicker Label="To" Date="@Filters.To" DateChanged="OnToChanged" /></MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="string" Label="Workout Split" Value="@Filters.Title" ValueChanged="OnTitleChanged">
                    <MudSelectItem T="string" Value="@string.Empty">All splits</MudSelectItem>
                    @foreach (var title in _titleOptions)
                    {
                        <MudSelectItem T="string" Value="@title">@title</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="string" Label="Exercise" Value="@Filters.Exercise" ValueChanged="OnExerciseChanged">
                    @foreach (var exercise in _exerciseOptions)
                    {
                        <MudSelectItem T="string" Value="@exercise">@exercise</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @if (_selectedRecord is not null)
    {
        <MudGrid Class="mt-4">
            <MudItem xs="12" sm="6" md="3"><StatCard Label="Heaviest Set" Value="@($"{HevyAnalytics.FormatNumber(_selectedRecord.HeaviestSet.Weight)} kg")" Subtitle="@($"{_selectedRecord.HeaviestSet.Reps} reps")" /></MudItem>
            <MudItem xs="12" sm="6" md="3"><StatCard Label="Best Estimated 1RM" Value="@($"{HevyAnalytics.FormatNumber(_selectedRecord.BestEstimatedOneRepMax.EstimatedOneRepMax)} kg")" /></MudItem>
            <MudItem xs="12" sm="6" md="3"><StatCard Label="Most Reps" Value="@_selectedRecord.BestRepSet.Reps.ToString()" Subtitle="@($"{HevyAnalytics.FormatNumber(_selectedRecord.BestRepSet.Weight)} kg")" /></MudItem>
            <MudItem xs="12" sm="6" md="3"><StatCard Label="Best Session Volume" Value="@($"{HevyAnalytics.FormatNumber(_selectedRecord.BestSessionVolume.TotalVolume)} kg")" Subtitle="@_selectedRecord.BestSessionVolume.Date?.ToShortDateString()" /></MudItem>
        </MudGrid>
    }

    <MudPaper Class="content-panel mt-4" Variant="Variant.Outlined">
        <MudText Typo="Typo.h6" GutterBottom="true">Record Progress</MudText>
        <MudSimpleTable Dense="true">
            <thead><tr><th>Date</th><th>Top Weight</th><th>Estimated 1RM</th><th>Session Volume</th></tr></thead>
            <tbody>
                @foreach (var point in _progress)
                {
                    <tr><td>@point.Date.ToShortDateString()</td><td>@HevyAnalytics.FormatNumber(point.TopWeight) kg</td><td>@HevyAnalytics.FormatNumber(point.EstimatedOneRepMax) kg</td><td>@HevyAnalytics.FormatNumber(point.TotalVolume) kg</td></tr>
                }
            </tbody>
        </MudSimpleTable>
    </MudPaper>

    <MudPaper Class="content-panel mt-4" Variant="Variant.Outlined">
        <MudText Typo="Typo.h6" GutterBottom="true">Exercise Record Leaderboard</MudText>
        <MudSimpleTable Dense="true">
            <thead><tr><th>Exercise</th><th>Heaviest Set</th><th>Best Est. 1RM</th><th>Most Reps</th><th>Best Session Volume</th></tr></thead>
            <tbody>
                @foreach (var item in _records)
                {
                    <tr>
                        <td>@item.Exercise</td>
                        <td>@HevyAnalytics.FormatNumber(item.HeaviestSet.Weight)kg x @item.HeaviestSet.Reps</td>
                        <td>@HevyAnalytics.FormatNumber(item.BestEstimatedOneRepMax.EstimatedOneRepMax) kg</td>
                        <td>@item.BestRepSet.Reps @(" @ ") @HevyAnalytics.FormatNumber(item.BestRepSet.Weight)kg</td>
                        <td>@HevyAnalytics.FormatNumber(item.BestSessionVolume.TotalVolume) kg</td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    </MudPaper>
}

@code {
    private IReadOnlyList<string> _titleOptions = [];
    private IReadOnlyList<string> _exerciseOptions = [];
    private IReadOnlyList<ExerciseRecordSummary> _records = [];
    private ExerciseRecordSummary? _selectedRecord;
    private IReadOnlyList<RecordProgressPoint> _progress = [];

    protected override string StorageKey => "hevyAnalyzer.filters.records";
    protected override ExerciseSelectionFilters DefaultFilters => new();

    protected override Task OnRowsLoadedAsync()
    {
        _titleOptions = HevyAnalytics.GetWorkoutTitleOptions(AllRows);
        if (!string.IsNullOrWhiteSpace(Filters.Title) && !_titleOptions.Contains(Filters.Title))
        {
            Filters.Title = string.Empty;
        }

        var rows = HevyAnalytics.FilterRows(AllRows, Filters);
        _records = HevyAnalytics.GetExerciseRecords(rows);
        _exerciseOptions = _records.Select(item => item.Exercise).ToList();
        if (!_exerciseOptions.Contains(Filters.Exercise))
        {
            Filters.Exercise = _exerciseOptions.FirstOrDefault() ?? string.Empty;
        }

        _selectedRecord = _records.FirstOrDefault(item => string.Equals(item.Exercise, Filters.Exercise, StringComparison.OrdinalIgnoreCase));
        _progress = string.IsNullOrWhiteSpace(Filters.Exercise) ? [] : HevyAnalytics.GetExerciseRecordProgress(rows, Filters.Exercise);
        return Task.CompletedTask;
    }

    private async Task OnFromChanged(DateTime? value) { Filters.From = value; await PersistAndReloadAsync(); }
    private async Task OnToChanged(DateTime? value) { Filters.To = value; await PersistAndReloadAsync(); }
    private async Task OnTitleChanged(string value) { Filters.Title = value; await PersistAndReloadAsync(); }
    private async Task OnExerciseChanged(string value) { Filters.Exercise = value; await PersistAndReloadAsync(); }
}
