@page "/frequency"
@inherits HevyPageBase<DateTitleFilters>

<PageTitle>Frequency</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Frequency</MudText>

@if (IsLoading)
{
    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
}
else if (!HasData)
{
    <MudAlert Severity="Severity.Info">@ErrorMessage</MudAlert>
}
else
{
    <MudPaper Class="filter-panel" Variant="Variant.Outlined">
        <MudGrid>
            <MudItem xs="12" sm="6" md="3"><MudDatePicker Label="From" Date="@Filters.From" DateChanged="OnFromChanged" /></MudItem>
            <MudItem xs="12" sm="6" md="3"><MudDatePicker Label="To" Date="@Filters.To" DateChanged="OnToChanged" /></MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudSelect T="string" Label="Workout Split" Value="@Filters.Title" ValueChanged="OnTitleChanged">
                    <MudSelectItem T="string" Value="@string.Empty">All splits</MudSelectItem>
                    @foreach (var title in _titleOptions)
                    {
                        <MudSelectItem T="string" Value="@title">@title</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="2" Class="d-flex align-end"><MudButton Variant="Variant.Outlined" OnClick="ResetFiltersAsync">Reset</MudButton></MudItem>
        </MudGrid>
    </MudPaper>

    <MudGrid Class="mt-4">
        <MudItem xs="12" sm="4"><StatCard Label="Tracked Weeks" Value="@_weeklyFrequency.Count.ToString()" /></MudItem>
        <MudItem xs="12" sm="4"><StatCard Label="Avg Workouts / Week" Value="@_avgWeekly.ToString("F1")" /></MudItem>
        <MudItem xs="12" sm="4"><StatCard Label="Top Split" Value="@_topSplit" Subtitle="@_topSplitSubtitle" /></MudItem>
    </MudGrid>

    <MudGrid Class="mt-4">
        <MudItem xs="12" lg="6">
            <MudPaper Class="content-panel" Variant="Variant.Outlined">
                <MudText Typo="Typo.h6" GutterBottom="true">Weekly Frequency</MudText>
                <MudSimpleTable Dense="true">
                    <thead><tr><th>Week</th><th>Workouts</th></tr></thead>
                    <tbody>
                        @foreach (var point in _weeklyFrequency)
                        {
                            <tr><td>@point.Label</td><td>@point.Value</td></tr>
                        }
                    </tbody>
                </MudSimpleTable>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" lg="6">
            <MudPaper Class="content-panel" Variant="Variant.Outlined">
                <MudText Typo="Typo.h6" GutterBottom="true">RPE Distribution</MudText>
                <MudSimpleTable Dense="true">
                    <thead><tr><th>RPE</th><th>Count</th></tr></thead>
                    <tbody>
                        @foreach (var rpe in _rpeDistribution)
                        {
                            <tr><td>@rpe.Rpe</td><td>@rpe.Count</td></tr>
                        }
                    </tbody>
                </MudSimpleTable>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudPaper Class="content-panel mt-4" Variant="Variant.Outlined">
        <MudText Typo="Typo.h6" GutterBottom="true">Monthly Split Balance</MudText>
        <MudSimpleTable Dense="true">
            <thead><tr><th>Month</th><th>Split Counts</th></tr></thead>
            <tbody>
                @foreach (var month in _monthlySplitCounts)
                {
                    <tr><td>@month.Month</td><td>@string.Join(", ", month.Counts.Select(item => $"{item.Key}: {item.Value}"))</td></tr>
                }
            </tbody>
        </MudSimpleTable>
    </MudPaper>
}

@code {
    private IReadOnlyList<string> _titleOptions = [];
    private IReadOnlyList<VolumePoint> _weeklyFrequency = [];
    private IReadOnlyList<RpeBucket> _rpeDistribution = [];
    private IReadOnlyList<MonthlySplitCounts> _monthlySplitCounts = [];
    private double _avgWeekly;
    private string _topSplit = "-";
    private string _topSplitSubtitle = string.Empty;

    protected override string StorageKey => "hevyAnalyzer.filters.frequency";
    protected override DateTitleFilters DefaultFilters => new();

    protected override Task OnRowsLoadedAsync()
    {
        _titleOptions = HevyAnalytics.GetWorkoutTitleOptions(AllRows);
        if (!string.IsNullOrWhiteSpace(Filters.Title) && !_titleOptions.Contains(Filters.Title))
        {
            Filters.Title = string.Empty;
        }

        var rows = HevyAnalytics.FilterRows(AllRows, Filters);
        _weeklyFrequency = HevyAnalytics.GetWeeklyFrequency(rows);
        _rpeDistribution = HevyAnalytics.GetRpeDistribution(rows);
        _monthlySplitCounts = HevyAnalytics.GetMonthlySplitCounts(rows);
        _avgWeekly = _weeklyFrequency.Count > 0 ? _weeklyFrequency.Average(item => item.Value) : 0;

        var topSplit = HevyAnalytics.GetSplitDistribution(rows).FirstOrDefault();
        _topSplit = topSplit?.Title ?? "-";
        _topSplitSubtitle = topSplit is null ? string.Empty : $"{topSplit.Count} workouts";
        return Task.CompletedTask;
    }

    private async Task OnFromChanged(DateTime? value) { Filters.From = value; await PersistAndReloadAsync(); }
    private async Task OnToChanged(DateTime? value) { Filters.To = value; await PersistAndReloadAsync(); }
    private async Task OnTitleChanged(string value) { Filters.Title = value; await PersistAndReloadAsync(); }
}
