@page "/sessions"
@inherits HevyPageBase<DateTitleFilters>

<PageTitle>Sessions</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Sessions</MudText>

@if (IsLoading)
{
    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
}
else if (!HasData)
{
    <MudAlert Severity="Severity.Info">@ErrorMessage</MudAlert>
}
else
{
    <MudPaper Class="filter-panel" Variant="Variant.Outlined">
        <MudGrid>
            <MudItem xs="12" sm="6" md="3"><MudDatePicker Label="From" Date="@Filters.From" DateChanged="OnFromChanged" /></MudItem>
            <MudItem xs="12" sm="6" md="3"><MudDatePicker Label="To" Date="@Filters.To" DateChanged="OnToChanged" /></MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudSelect T="string" Label="Workout Split" Value="@Filters.Title" ValueChanged="OnTitleChanged">
                    <MudSelectItem T="string" Value="@string.Empty">All splits</MudSelectItem>
                    @foreach (var title in _titleOptions)
                    {
                        <MudSelectItem T="string" Value="@title">@title</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="2" Class="d-flex align-end"><MudButton Variant="Variant.Outlined" OnClick="ResetFiltersAsync">Reset</MudButton></MudItem>
        </MudGrid>
    </MudPaper>

    <MudGrid Class="mt-4">
        <MudItem xs="12" sm="6" md="3"><StatCard Label="Average Duration" Value="@($"{Math.Round(_avgDuration)} min")" /></MudItem>
        <MudItem xs="12" sm="6" md="3"><StatCard Label="Average Sets / Min" Value="@_avgSetsPerMinute.ToString("F2")" /></MudItem>
        <MudItem xs="12" sm="6" md="3"><StatCard Label="Average Volume / Min" Value="@($"{HevyAnalytics.FormatNumber(_avgVolumePerMinute)} kg")" /></MudItem>
        <MudItem xs="12" sm="6" md="3"><StatCard Label="Highest Density" Value="@_highestDensityTitle" Subtitle="@_highestDensitySubtitle" /></MudItem>
    </MudGrid>

    <MudPaper Class="content-panel mt-4" Variant="Variant.Outlined">
        <MudText Typo="Typo.h6" GutterBottom="true">Recent Sessions</MudText>
        <MudSimpleTable Dense="true">
            <thead><tr><th>Date</th><th>Split</th><th>Duration</th><th>Sets</th><th>Sets / Min</th><th>Volume / Min</th></tr></thead>
            <tbody>
                @foreach (var session in _sessions.Take(12))
                {
                    <tr>
                        <td>@session.Start.ToShortDateString()</td>
                        <td>@session.Title</td>
                        <td>@Math.Round(session.DurationMin) min</td>
                        <td>@session.TotalSets</td>
                        <td>@session.SetsPerMinute.ToString("F2")</td>
                        <td>@HevyAnalytics.FormatNumber(session.VolumePerMinute)</td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    </MudPaper>

    <MudPaper Class="content-panel mt-4" Variant="Variant.Outlined">
        <MudText Typo="Typo.h6" GutterBottom="true">Monthly Split Balance</MudText>
        <MudSimpleTable Dense="true">
            <thead><tr><th>Month</th><th>Split Counts</th></tr></thead>
            <tbody>
                @foreach (var month in _monthlySplitCounts)
                {
                    <tr><td>@month.Month</td><td>@string.Join(", ", month.Counts.Select(item => $"{item.Key}: {item.Value}"))</td></tr>
                }
            </tbody>
        </MudSimpleTable>
    </MudPaper>
}

@code {
    private IReadOnlyList<string> _titleOptions = [];
    private IReadOnlyList<SessionSummary> _sessions = [];
    private IReadOnlyList<MonthlySplitCounts> _monthlySplitCounts = [];
    private double _avgDuration;
    private double _avgSetsPerMinute;
    private double _avgVolumePerMinute;
    private string _highestDensityTitle = "-";
    private string _highestDensitySubtitle = string.Empty;

    protected override string StorageKey => "hevyAnalyzer.filters.sessions";
    protected override DateTitleFilters DefaultFilters => new();

    protected override Task OnRowsLoadedAsync()
    {
        _titleOptions = HevyAnalytics.GetWorkoutTitleOptions(AllRows);
        if (!string.IsNullOrWhiteSpace(Filters.Title) && !_titleOptions.Contains(Filters.Title))
        {
            Filters.Title = string.Empty;
        }

        var rows = HevyAnalytics.FilterRows(AllRows, Filters);
        _sessions = HevyAnalytics.GetSessionStats(rows);
        _monthlySplitCounts = HevyAnalytics.GetMonthlySplitCounts(rows);
        _avgDuration = _sessions.Count > 0 ? _sessions.Average(item => item.DurationMin) : 0;
        _avgSetsPerMinute = _sessions.Count > 0 ? _sessions.Average(item => item.SetsPerMinute) : 0;
        _avgVolumePerMinute = _sessions.Count > 0 ? _sessions.Average(item => item.VolumePerMinute) : 0;
        var efficient = _sessions.OrderByDescending(item => item.VolumePerMinute).FirstOrDefault();
        _highestDensityTitle = efficient?.Title ?? "-";
        _highestDensitySubtitle = efficient is null ? string.Empty : $"{HevyAnalytics.FormatNumber(efficient.VolumePerMinute)} kg/min";
        return Task.CompletedTask;
    }

    private async Task OnFromChanged(DateTime? value) { Filters.From = value; await PersistAndReloadAsync(); }
    private async Task OnToChanged(DateTime? value) { Filters.To = value; await PersistAndReloadAsync(); }
    private async Task OnTitleChanged(string value) { Filters.Title = value; await PersistAndReloadAsync(); }
}
