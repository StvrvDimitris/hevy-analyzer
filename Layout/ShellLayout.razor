@inherits LayoutComponentBase
@implements IDisposable
@inject HevyDataService DataService
@inject ISnackbar Snackbar

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6">Hevy Analyzer</MudText>
        <MudSpacer />
        <MudButton HtmlTag="label" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.UploadFile">
            Import CSV
            <InputFile OnChange="ImportCsvAsync" accept=".csv,text/csv" hidden />
        </MudButton>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="1" Variant="DrawerVariant.Responsive">
        <MudNavMenu Class="pa-4">
            <MudText Typo="Typo.overline" Class="mb-2">Pages</MudText>
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
            <MudNavLink Href="/exercises" Icon="@Icons.Material.Filled.FitnessCenter">Exercises</MudNavLink>
            <MudNavLink Href="/progress" Icon="@Icons.Material.Filled.ShowChart">Progress</MudNavLink>
            <MudNavLink Href="/frequency" Icon="@Icons.Material.Filled.CalendarMonth">Frequency</MudNavLink>
            <MudNavLink Href="/strength" Icon="@Icons.Material.Filled.Bolt">Strength</MudNavLink>
            <MudNavLink Href="/sessions" Icon="@Icons.Material.Filled.Schedule">Sessions</MudNavLink>
            <MudNavLink Href="/consistency" Icon="@Icons.Material.Filled.Insights">Consistency</MudNavLink>
            <MudNavLink Href="/conditioning" Icon="@Icons.Material.Filled.DirectionsRun">Conditioning</MudNavLink>
            <MudNavLink Href="/records" Icon="@Icons.Material.Filled.EmojiEvents">Records</MudNavLink>
            <MudNavLink Href="/analysis" Icon="@Icons.Material.Filled.Analytics">Analysis</MudNavLink>

            <MudDivider Class="my-4" />

            <MudPaper Class="pa-3 status-panel" Variant="Variant.Outlined">
                <MudText Typo="Typo.caption" Class="text-uppercase">Imported CSV</MudText>
                <MudText Typo="Typo.body2">@(!string.IsNullOrWhiteSpace(_fileName) ? _fileName : "No CSV imported")</MudText>
            </MudPaper>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.False" Class="page-shell">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private string _fileName = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        DataService.Changed += HandleDataChanged;
        await DataService.InitializeAsync();
        _fileName = DataService.FileName;
    }

    private void ToggleDrawer()
        => _drawerOpen = !_drawerOpen;

    private async Task ImportCsvAsync(InputFileChangeEventArgs args)
    {
        var file = args.File;
        if (file is null)
        {
            return;
        }

        try
        {
            await DataService.ImportAsync(file);
            _fileName = DataService.FileName;
            Snackbar.Add($"Imported {file.Name}", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async void HandleDataChanged()
    {
        _fileName = DataService.FileName;
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        DataService.Changed -= HandleDataChanged;
    }
}
